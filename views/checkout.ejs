 

 <%- include('partials/header') %>
<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 px-4 md:px-10 py-12">
<!-- Left Column: Checkout Forms -->
<div class="lg:col-span-7">
<!-- Navigation Breadcrumbs -->
<nav class="flex items-center gap-2 mb-8 text-sm font-medium">
<a class="text-primary" href="#">Shipping</a>
<span class="text-slate-400"><span class="material-symbols-outlined">chevron_right</span></span>
<span class="text-slate-400">Delivery</span>
<span class="text-slate-400"><span class="material-symbols-outlined">chevron_right</span></span>
<span class="text-slate-400">Payment</span>
</nav>
<!-- Express Checkout -->
<div class="mb-10">
<h2 class="text-center text-slate-500 text-xs font-bold uppercase tracking-widest mb-4">Express Checkout</h2>
<div class="grid grid-cols-2 gap-4">
<button class="flex items-center justify-center h-12 rounded-lg bg-slate-900 text-white font-bold hover:bg-slate-800 transition-colors">
<span class="mr-1">Apple Pay</span>
</button>
<button class="flex items-center justify-center h-12 rounded-lg bg-[#5a31f4] text-white font-bold hover:bg-[#4a28c7] transition-colors">
<span class="mr-1">Shop Pay</span>
</button>
</div>
<div class="relative flex py-8 items-center">
<div class="flex-grow border-t border-slate-200 dark:border-slate-800"></div>
<span class="flex-shrink mx-4 text-slate-400 text-xs uppercase font-bold tracking-widest">OR</span>
<div class="flex-grow border-t border-slate-200 dark:border-slate-800"></div>
</div>
</div>
<!-- Shipping Form -->
<section>
<div class="flex items-center justify-between mb-6">
<h2 class="text-xl font-bold">Shipping Information</h2>
<a class="text-primary text-sm font-medium" href="#">Log in</a>
</div>
<form class="space-y-4">
<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
<div>
<label class="block text-sm font-medium mb-1 text-slate-600 dark:text-slate-400">First Name</label>
<input class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="Jane" type="text"/>
</div>
<div>
<label class="block text-sm font-medium mb-1 text-slate-600 dark:text-slate-400">Last Name</label>
<input class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="Doe" type="text"/>
</div>
</div>
<div>
<label class="block text-sm font-medium mb-1 text-slate-600 dark:text-slate-400">Address</label>
<input class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="Street address" type="text"/>
</div>
<div>
<label class="block text-sm font-medium mb-1 text-slate-600 dark:text-slate-400">Apartment, suite, etc. (optional)</label>
<input class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="Apt 4B" type="text"/>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
<div>
<label class="block text-sm font-medium mb-1 text-slate-600 dark:text-slate-400">City</label>
<input class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="New York" type="text"/>
</div>
<div>
<label class="block text-sm font-medium mb-1 text-slate-600 dark:text-slate-400">State</label>
<select class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3 appearance-none">
<option>New York</option>
<option>California</option>
<option>Texas</option>
</select>
</div>
<div>
<label class="block text-sm font-medium mb-1 text-slate-600 dark:text-slate-400">ZIP code</label>
<input class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="10001" type="text"/>
</div>
</div>
<div class="pt-6">
<button class="w-full md:w-auto px-8 py-4 bg-primary text-white font-bold rounded-lg hover:bg-primary/90 transition-all flex items-center justify-center gap-2" type="submit">
                                Continue to Delivery
</button>
</div>
</form>
</section>
</div>
<!-- Right Column: Order Summary -->
<div class="lg:col-span-5">
<div class="bg-white dark:bg-slate-900/50 rounded-xl border border-slate-200 dark:border-slate-800 p-6 sticky top-8">
<h2 class="text-xl font-bold mb-6">Order Summary</h2>
<div class="space-y-6 mb-8">
<!-- Product Item -->
<div class="flex gap-4">
<div class="relative h-20 w-20 flex-shrink-0 bg-background-light dark:bg-slate-800 rounded-lg overflow-hidden">
<img class="h-full w-full object-cover" data-alt="Premium glass serum bottle on neutral background" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCIQxN0134IrbM-CfI03jo9c6lcT-pC5d8iFRPKreKgeue1pThIOPqQtZi_-Ut5WaNAcuXPGbFOjjz6dbdp6tBXtDktHh6sQyagAae7bhHtLYgPWGEnlMnZ6rt6oI1TafFrziqFdZVUzVh_mrSvvilwgk5055ycT-vC5rO7w-CdEJW5jL4cIWscqu5cy-VFrpfnPVFubwdt5zNVANgB2oD9GT-abHX22-1qtdXxqIYtwrthe39DhO_Sx7T50fCv3abFo3rEUgIGa9u1"/>
<span class="absolute -top-2 -right-2 h-5 w-5 bg-slate-500 text-white text-[10px] flex items-center justify-center rounded-full">1</span>
</div>
<div class="flex flex-col justify-center flex-1">
<h3 class="text-sm font-semibold">Vitamin C Radiance Serum</h3>
<p class="text-xs text-slate-500">30ml / 1.0 fl oz</p>
</div>
<div class="flex items-center">
<span class="text-sm font-bold">$84.00</span>
</div>
</div>
<!-- Product Item -->
<div class="flex gap-4">
<div class="relative h-20 w-20 flex-shrink-0 bg-background-light dark:bg-slate-800 rounded-lg overflow-hidden">
<img class="h-full w-full object-cover" data-alt="Organic face moisturizer cream jar" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDRmrfsH2w7Fpp-_3MWf1otzb3KtQROQF5d9jytG7vPuUpFnTvoEPZS_UoZBqw_SFh49iRpA7EwqCtok3BoRaD-siRhJN5SwphMqDo0jwUYHW3eESaVNvj5L2U1zm3MNlVUD9j9ddDsZwxuiHOg93hxlT6pV6R6Mbx4yuZyVpZy62rXJ9gKlfOL45x0uYXeUtK7stnYwLGVK8YQ28gFCrsyOBnlc4njGN6rBk2kry46qGilnSvofsDFZKr9XzXNHfu3_NTEk7NSqBfW"/>
<span class="absolute -top-2 -right-2 h-5 w-5 bg-slate-500 text-white text-[10px] flex items-center justify-center rounded-full">1</span>
</div>
<div class="flex flex-col justify-center flex-1">
<h3 class="text-sm font-semibold">Dewy Glow Moisturizer</h3>
<p class="text-xs text-slate-500">50ml / 1.7 fl oz</p>
</div>
<div class="flex items-center">
<span class="text-sm font-bold">$62.00</span>
</div>
</div>
</div>
<!-- Promo Code -->
<div class="flex gap-3 mb-8">
<input class="flex-1 rounded-lg border-slate-200 dark:border-slate-800 bg-transparent focus:ring-primary focus:border-primary px-4 py-3 text-sm" placeholder="Gift card or discount code" type="text"/>
<button class="bg-primary/20 text-primary font-bold px-6 py-3 rounded-lg hover:bg-primary/30 transition-colors text-sm">Apply</button>
</div>
<!-- Totals -->
<div class="space-y-3 pt-6 border-t border-slate-200 dark:border-slate-800">
<div class="flex justify-between text-sm">
<span class="text-slate-500">Subtotal</span>
<span class="font-medium">$146.00</span>
</div>
<div class="flex justify-between text-sm">
<span class="text-slate-500">Shipping</span>
<span class="text-slate-500">Calculated at next step</span>
</div>
<div class="flex justify-between text-sm">
<span class="text-slate-500">Estimated Taxes</span>
<span class="text-slate-500">$12.40</span>
</div>
<div class="flex justify-between text-lg font-bold pt-3 border-t border-slate-200 dark:border-slate-800">
<span>Total</span>
<div class="flex flex-col items-end">
<span>$158.40</span>
</div>
</div>
</div>
<!-- Trust Badges -->
<div class="mt-8 flex justify-center gap-6 text-slate-400">
<div class="flex flex-col items-center gap-1">
<span class="material-symbols-outlined text-2xl">verified_user</span>
<span class="text-[10px] uppercase font-bold tracking-tighter">Secure Payment</span>
</div>
<div class="flex flex-col items-center gap-1">
<span class="material-symbols-outlined text-2xl">eco</span>
<span class="text-[10px] uppercase font-bold tracking-tighter">Sustainable</span>
</div>
<div class="flex flex-col items-center gap-1">
<span class="material-symbols-outlined text-2xl">package_2</span>
<span class="text-[10px] uppercase font-bold tracking-tighter">Free Shipping</span>
</div>
</div>
</div>
</div>
</div>
<%- include('partials/footer') %>