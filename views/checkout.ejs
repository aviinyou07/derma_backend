<%- include('partials/header') %>
<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 px-4 md:px-10 py-12">
    <div class="lg:col-span-7">
        <nav class="flex items-center gap-2 mb-8 text-sm font-medium">
            <span class="text-primary">Shipping</span>
            <span class="text-slate-400"><span class="material-symbols-outlined">chevron_right</span></span>
            <span class="text-slate-400">Payment</span>
        </nav>

        <section>
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-xl font-bold">Shipping Information</h2>
            </div>
            <p class="text-sm text-slate-500 dark:text-slate-400 mb-4">Checkout is available for signed-in users only.</p>

            <form id="checkout-form" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium mb-1 text-slate-600 dark:text-slate-400">First Name</label>
                        <input id="checkout-first-name" class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="Jane" type="text"/>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-slate-600 dark:text-slate-400">Last Name</label>
                        <input id="checkout-last-name" class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="Doe" type="text"/>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium mb-1 text-slate-600 dark:text-slate-400">Email</label>
                    <input id="checkout-email" class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="you@example.com" type="email"/>
                </div>

                <div>
                    <label class="block text-sm font-medium mb-1 text-slate-600 dark:text-slate-400">Address</label>
                    <input id="checkout-line1" class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="Street address" type="text"/>
                </div>

                <div>
                    <label class="block text-sm font-medium mb-1 text-slate-600 dark:text-slate-400">Apartment, suite, etc. (optional)</label>
                    <input id="checkout-line2" class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="Apt 4B" type="text"/>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div>
                        <label class="block text-sm font-medium mb-1 text-slate-600 dark:text-slate-400">City</label>
                        <input id="checkout-city" class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="City" type="text"/>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-slate-600 dark:text-slate-400">State</label>
                        <input id="checkout-state" class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="State" type="text"/>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-slate-600 dark:text-slate-400">ZIP code</label>
                        <input id="checkout-postal-code" class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="100001" type="text"/>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium mb-1 text-slate-600 dark:text-slate-400">Phone</label>
                    <input id="checkout-phone" class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="9876543210" type="text"/>
                </div>

                <label class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400">
                    <input id="checkout-save-address" type="checkbox" class="rounded border-slate-300" checked>
                    Save this address to my account
                </label>

                <div>
                    <label class="block text-sm font-medium mb-2 text-slate-600 dark:text-slate-400">Payment Method</label>
                    <div class="flex gap-3">
                        <label class="flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700">
                            <input type="radio" name="checkout-payment-method" value="cod" checked>
                            <span class="text-sm">Cash on Delivery</span>
                        </label>
                        <label class="flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700">
                            <input type="radio" name="checkout-payment-method" value="razorpay">
                            <span class="text-sm">Razorpay</span>
                        </label>
                    </div>
                </div>

                <div class="pt-6">
                    <button class="w-full md:w-auto px-8 py-4 bg-primary text-white font-bold rounded-lg hover:bg-primary/90 transition-all flex items-center justify-center gap-2" type="submit">
                        Place Order
                    </button>
                </div>
            </form>
        </section>
    </div>

    <div class="lg:col-span-5">
        <div class="bg-white dark:bg-slate-900/50 rounded-xl border border-slate-200 dark:border-slate-800 p-6 sticky top-8">
            <h2 class="text-xl font-bold mb-6">Order Summary</h2>

            <div class="mb-6">
                <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-2">Discount Code</label>
                <div class="flex gap-2">
                    <input id="checkout-coupon-code" class="flex-1 bg-background-light dark:bg-slate-800 border-none rounded-lg text-sm px-4 py-2.5 focus:ring-2 focus:ring-primary/50" placeholder="Enter code" type="text"/>
                    <button id="checkout-apply-coupon-btn" class="bg-primary/20 text-primary font-bold px-4 py-2 rounded-lg text-sm hover:bg-primary/30 transition-colors" type="button">Apply</button>
                    <button id="checkout-remove-coupon-btn" class="hidden bg-slate-100 text-slate-700 font-bold px-4 py-2 rounded-lg text-sm hover:bg-slate-200 transition-colors" type="button">Remove</button>
                </div>
                <p id="checkout-coupon-message" class="text-xs text-slate-500 mt-2"></p>
            </div>

            <div id="checkout-items" class="space-y-6 mb-8"></div>

            <div id="checkout-summary" class="space-y-3 pt-6 border-t border-slate-200 dark:border-slate-800">
                <div class="flex justify-between text-sm">
                    <span class="text-slate-500">Subtotal</span>
                    <span class="font-medium">₹0.00</span>
                </div>
                <div class="flex justify-between text-sm">
                    <span class="text-slate-500">Shipping</span>
                    <span class="text-slate-500">₹0.00</span>
                </div>
                <div class="flex justify-between text-sm">
                    <span class="text-slate-500">Estimated Taxes</span>
                    <span class="text-slate-500">₹0.00</span>
                </div>
                <div class="flex justify-between text-lg font-bold pt-3 border-t border-slate-200 dark:border-slate-800">
                    <span>Total</span>
                    <span>₹0.00</span>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="/js/pages/checkout.page.js"></script>
<%- include('partials/footer') %>