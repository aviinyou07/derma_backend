<p class="text-slate-600 dark:text-slate-400 max-w-lg mx-auto">Real results from our 8-week clinical study with daily product use.</p>
</div>
<div class="relative max-w-4xl mx-auto rounded-2xl overflow-hidden shadow-2xl">
<div class="grid grid-cols-2">
<div class="relative">
<img class="w-full h-[400px] object-cover" data-alt="Before treatment skin with uneven tone" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC4pDGrQAEyf-TUGcGWDvqXo8PU_5UHiNLxLrmRk1dM0b2Ghjq4w-ij5XkLK1F-7JzHRjSQrVsAWizzAgR8SwKqlGdsyhGW7mbcKWSEuhODF7K326i5UwRxxI4TjOYC91bfiI8SqHHHRlGePPx_aq871BbvEHdujPpAH-89QERGckZonOv4W0xV5bcV8gL-GSHvDHmh3j0nGgdAjGoUjIJYUxig7PY1sprbom0HhVuUMheymeH4vGog9B5G3DQLApEDxa7ElLABPQAP"/>
<div class="absolute bottom-4 left-4 bg-black/50 backdrop-blur px-3 py-1 rounded text-white text-xs font-bold uppercase tracking-widest">Before</div>
</div>
<div class="relative">
<img class="w-full h-[400px] object-cover" data-alt="After 8 weeks treatment glowing skin" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC5oJti9LaK7BMjQ0ezvVOvPVUaV0LFj0V85QrzuQgdyee6-A4Oys2-dtHcWSMQD32pTRHOuUSXjcjydjBVDkwf4yqljDrUbFKCagwfBkAHm3X6IaVRyFMROzZ4LkFOjIlNb6Gwc6Ynwkc_K9Ufbb0n6xV5Gg1mWcQSBPgXx10ZUAF-sQLxsEwMWQpDcry1X113FEZmpT-dP9rXdh1tNdlkqTX9ody9YYqjwx6xpZwD2Bu0wZ2ysk4j8dhJDRQTz04wF9zylyc6T57x"/>
<div class="absolute bottom-4 right-4 bg-primary px-3 py-1 rounded text-slate-900 text-xs font-bold uppercase tracking-widest">After 8 Weeks</div>
</div>
</div>
</div>
</section>
<!-- Related Products Section -->
<section class="pb-20">
<div class="flex justify-between items-end mb-8">
<div>
<h2 class="text-2xl font-black">Pairs Perfectly With</h2>
<p class="text-slate-500">Complete your routine for maximum results</p>
</div>
<div class="flex gap-2">
<button class="p-2 rounded-full border border-slate-200 dark:border-slate-800 hover:bg-white dark:hover:bg-slate-800 transition-colors">
<span class="material-symbols-outlined">west</span>
</button>
<button class="p-2 rounded-full border border-slate-200 dark:border-slate-800 hover:bg-white dark:hover:bg-slate-800 transition-colors">
<span class="material-symbols-outlined">east</span>
</button>
</div>
</div>
<div id="pd-related-grid" class="flex gap-4 pb-4 mb-4"></div>

</section>
</main>

<script src="/js/pages/productdetails.page.js"></script>

<%- include('partials/footer') %>