

<%- include('partials/header') %>
<main class=" px-4 md:px-10 lg:px-10 py-8">
<!-- Breadcrumbs -->
<div class="flex items-center gap-2 mb-8 text-sm text-slate-500 dark:text-slate-400">
<a class="hover:text-primary" href="/">Home</a>
<span class="material-symbols-outlined text-xs">chevron_right</span>
<a class="hover:text-primary" href="/productlist">Shop</a>
<span class="material-symbols-outlined text-xs">chevron_right</span>
<span id="pd-breadcrumb-name" class="text-slate-900 dark:text-slate-100 font-medium">Product</span>
</div>
<!-- Product Detail Section -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-20">
<!-- Left: Product Images -->
<div class="space-y-4">
<div class="aspect-[4/5] w-full rounded-xl overflow-hidden bg-slate-100 dark:bg-slate-800">
<img id="pd-main-image" class="w-full h-full object-cover" data-alt="Product image" src=""/>
</div>
<div id="pd-gallery" class="grid grid-cols-4 gap-4"></div>
</div>
<!-- Right: Product Details -->
<div class="flex flex-col gap-6">
<div>
<h1 id="pd-title" class="text-4xl font-black text-slate-900 dark:text-slate-100 mb-2 leading-tight">Loading product...</h1>
<div class="flex items-center gap-3">
<div class="flex text-primary">
<span class="material-symbols-outlined fill-1">star</span>
<span class="material-symbols-outlined fill-1">star</span>
<span class="material-symbols-outlined fill-1">star</span>
<span class="material-symbols-outlined fill-1">star</span>
<span class="material-symbols-outlined fill-1">star</span>
</div>
<span id="pd-review-count" class="text-sm font-medium text-slate-500 border-l border-slate-300 dark:border-slate-700 pl-3">0 Reviews</span>
</div>
</div>
<p id="pd-description" class="text-slate-600 dark:text-slate-400 text-lg leading-relaxed">-</p>
<div class="flex items-baseline gap-3">
<span id="pd-price" class="text-3xl font-bold">₹0.00</span>
<span id="pd-mrp" class="text-lg text-slate-400 line-through">₹0.00</span>
</div>
 
<!-- Options Selection -->
<div class="grid grid-cols-2 gap-4">
<div class="space-y-2">
<label class="text-sm font-bold uppercase tracking-wider text-slate-500">Size</label>
<select id="pd-variation" class="w-full bg-slate-50 dark:bg-slate-900 border-slate-200 dark:border-slate-800 rounded-lg p-3 focus:ring-primary focus:border-primary">
</select>
</div>
<div class="space-y-2">
<label class="text-sm font-bold uppercase tracking-wider text-slate-500">Quantity</label>
<div class="flex items-center bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg">
<button class="p-3 hover:text-primary transition-colors"><span class="material-symbols-outlined text-sm">remove</span></button>
<input id="pd-quantity" class="w-full bg-transparent border-none text-center focus:ring-0 font-bold" type="number" value="1"/>
<button class="p-3 hover:text-primary transition-colors"><span class="material-symbols-outlined text-sm">add</span></button>
</div>
</div>
</div>
<button id="pd-add-to-cart" class="w-full bg-primary hover:bg-primary/90 text-slate-900 font-bold py-4 rounded-xl shadow-lg shadow-primary/20 transition-all active:scale-[0.98]">
                        ADD TO CART — ₹0.00
                    </button>
<button id="product-buy-now" class="w-full border border-primary text-primary font-bold py-3 rounded-xl hover:bg-primary/10 transition-all active:scale-[0.98]" type="button">
                        BUY NOW
                    </button>
<button id="pd-wishlist-btn" class="w-full border border-slate-300 dark:border-slate-700 text-slate-700 dark:text-slate-200 font-bold py-3 rounded-xl hover:bg-slate-100 dark:hover:bg-slate-800 transition-all active:scale-[0.98]" type="button">
                        ADD TO WISHLIST
                    </button>
<!-- Key Benefits -->
<div class="grid grid-cols-3 gap-4 pt-6 border-t border-slate-200 dark:border-slate-800">
<div class="flex flex-col items-center text-center gap-2">
<span class="material-symbols-outlined text-primary bg-primary/10 p-2 rounded-full">cruelty_free</span>
<span class="text-[10px] font-bold uppercase tracking-tighter">Cruelty Free</span>
</div>
<div class="flex flex-col items-center text-center gap-2">
<span class="material-symbols-outlined text-primary bg-primary/10 p-2 rounded-full">eco</span>
<span class="text-[10px] font-bold uppercase tracking-tighter">Vegan Formula</span>
</div>
<div class="flex flex-col items-center text-center gap-2">
<span class="material-symbols-outlined text-primary bg-primary/10 p-2 rounded-full">science</span>
<span class="text-[10px] font-bold uppercase tracking-tighter">Lab Tested</span>
</div>
</div>
<!-- Accordions -->
<div id="pd-accordions" class="mt-4 space-y-2"></div>
</div>
</div>
<!-- Before/After Section -->
