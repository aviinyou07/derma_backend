<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Professional Skincare Collection | Dermacare Elite</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#17cf91",
                        "background-light": "#f6f8f7",
                        "background-dark": "#11211c",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"},
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .product-card:hover .hover-image {
            opacity: 1;
        }
        .product-card:hover .default-image {
            opacity: 0;
        }
        /* Prevents content from being hidden behind the bottom nav on mobile */
        @media (max-width: 1024px) {
            body { padding-bottom: 70px; }
        }
    </style>
</head>  

<body class="  max-w-7xl mx-auto bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 transition-colors duration-300">
    <div>
        
        <header class=" sticky top-0 z-50 bg-white/80  backdrop-blur-md border-b border-slate-200 dark:border-slate-800 px-4 md:px-10 py-2">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-10">
                    <div class="flex items-center gap-3">
                        <div class="size-8 bg-primary rounded-lg flex items-center justify-center text-white">
                            <span class="material-symbols-outlined">spa</span>
                        </div>
                        <h2 class="text-slate-900 dark:text-white text-xl font-bold tracking-tight">Dermacare Elite</h2>
                    </div>
                    <nav class="hidden lg:flex items-center gap-8">
                        <a class="text-slate-600 dark:text-slate-300 text-sm font-medium hover:text-primary transition-colors" href="/productlist">Shop All</a>
                        <a class="text-slate-600 dark:text-slate-300 text-sm font-medium hover:text-primary transition-colors" href="/productlist?sort=trending">Best Sellers</a>
                        <a class="text-slate-600 dark:text-slate-300 text-sm font-medium hover:text-primary transition-colors" href="/productlist">Concerns</a>
                        <a class="text-slate-600 dark:text-slate-300 text-sm font-medium hover:text-primary transition-colors" href="/">About</a>
                    </nav>
                </div>

                <div class="flex items-center gap-4">
                    <div class="hidden lg:flex relative max-w-xs w-64">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
                        <input id="global-search-input" class="w-full bg-slate-100 dark:bg-slate-800 border-none rounded-full py-2 pl-10 pr-4 text-sm focus:ring-2 focus:ring-primary/50" placeholder="Search..." type="text"/>
                    </div>
                    
                    <button id="global-cart-button" class="p-2 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full">
                        <span class="material-symbols-outlined">shopping_bag</span>
                    </button>

                    <button id="global-account-button" class="hidden lg:block size-10 rounded-full bg-slate-200 dark:bg-slate-700 overflow-hidden border border-slate-200 dark:border-slate-700" type="button">
                        <img class="w-full h-full object-cover" alt="User profile" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCMC5lzI8OAMLq1mhZYIr-C9PEkhEumw38OtrWvLQviIaLbHtVBtzHBFd42S78nneTO65DjasXMOoNv1aZ69GiOASvy8upSP4bWtoO6bfnctYxH1J4RsONpQqLrgeF5tICpDOAnTFZRD3qDg5yhUsZNashmN2NjdlOuAH2ajv1egWbgO-YFmqLfIK2eDyy1hqju8Ynv5Omheu9Zz1LaIsJ46ZVvjXT6xmx76BzxH1geeev3eQwxMMWce6PI7rluJ7Bo5fI1TmfG6ec6"/>
                    </button>
                </div>
            </div>
        </header>

        <div id="app-toast-root" class="fixed top-4 right-4 z-[80] space-y-2 pointer-events-none"></div>

        <div id="app-prompt-modal" class="hidden fixed inset-0 z-[90] bg-slate-900/60 backdrop-blur-sm p-4 items-center justify-center">
            <div class="w-full max-w-md rounded-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 shadow-2xl p-6">
                <h3 id="app-prompt-title" class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-2"></h3>
                <p id="app-prompt-message" class="text-sm text-slate-500 dark:text-slate-400 mb-4"></p>
                <input id="app-prompt-input" class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" type="text" />
                <div class="mt-5 flex justify-end gap-2">
                    <button id="app-prompt-cancel" class="px-4 py-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-200 font-semibold" type="button">Cancel</button>
                    <button id="app-prompt-submit" class="px-4 py-2 rounded-lg bg-primary text-white font-semibold" type="button">Submit</button>
                </div>
            </div>
        </div>

        <div id="auth-modal" class="hidden fixed inset-0 z-[95] bg-slate-900/65 backdrop-blur-sm p-4 items-center justify-center">
            <div class="w-full max-w-lg rounded-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 shadow-2xl overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800 flex items-center justify-between">
                    <h3 class="text-xl font-bold">Welcome to Dermacare Elite</h3>
                    <button id="auth-close-btn" type="button" class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>

                <div class="p-6">
                    <div class="flex gap-2 mb-4">
                        <button id="auth-tab-login" class="flex-1 px-4 py-2 rounded-lg bg-primary text-white font-semibold" type="button">Login</button>
                        <button id="auth-tab-signup" class="flex-1 px-4 py-2 rounded-lg bg-slate-100 dark:bg-slate-800 font-semibold" type="button">Register</button>
                    </div>

                    <div id="auth-login-view">
                        <div class="space-y-3">
                            <input id="auth-login-identifier" class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="Email or phone" type="text" />
                            <input id="auth-login-password" class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="Password" type="password" />
                        </div>
                        <button id="auth-forgot-open-btn" class="mt-2 text-sm text-primary font-semibold hover:underline" type="button">Forgot password?</button>
                        <button id="auth-login-submit" class="w-full mt-4 px-4 py-3 rounded-lg bg-primary text-white font-bold" type="button">Login</button>
                    </div>

                    <div id="auth-signup-view" class="hidden">
                        <div class="space-y-3">
                            <input id="auth-signup-name" class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="Full name" type="text" />
                            <input id="auth-signup-email" class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="Email" type="email" />
                            <input id="auth-signup-password" class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="Password" type="password" />
                        </div>
                        <button id="auth-signup-submit" class="w-full mt-4 px-4 py-3 rounded-lg bg-primary text-white font-bold" type="button">Create account</button>
                    </div>

                    <div id="auth-verify-view" class="hidden">
                        <p class="text-sm text-slate-500 dark:text-slate-400 mb-3">Enter the OTP sent to your email to verify and activate account.</p>
                        <input id="auth-verify-otp" class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="6-digit OTP" type="text" />
                        <button id="auth-verify-submit" class="w-full mt-4 px-4 py-3 rounded-lg bg-primary text-white font-bold" type="button">Verify email</button>
                        <button id="auth-resend-otp-btn" class="w-full mt-2 px-4 py-3 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-200 font-semibold disabled:opacity-60" type="button">Resend OTP</button>
                        <p id="auth-resend-timer" class="mt-2 text-xs text-slate-500 dark:text-slate-400"></p>
                    </div>

                    <div id="auth-forgot-view" class="hidden">
                        <p class="text-sm text-slate-500 dark:text-slate-400 mb-3">Enter your account email to receive password reset OTP.</p>
                        <input id="auth-forgot-email" class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="Email" type="email" />
                        <button id="auth-forgot-submit" class="w-full mt-4 px-4 py-3 rounded-lg bg-primary text-white font-bold" type="button">Send reset OTP</button>
                    </div>

                    <div id="auth-reset-view" class="hidden">
                        <p class="text-sm text-slate-500 dark:text-slate-400 mb-3">Enter OTP and set a new password.</p>
                        <input id="auth-reset-email" class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-slate-100 dark:bg-slate-800 px-4 py-3 mb-3" placeholder="Email" type="email" readonly />
                        <input id="auth-reset-otp" class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3 mb-3" placeholder="6-digit OTP" type="text" />
                        <input id="auth-reset-password" class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3 mb-3" placeholder="New password" type="password" />
                        <input id="auth-reset-password-confirm" class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 focus:ring-primary focus:border-primary px-4 py-3" placeholder="Confirm new password" type="password" />
                        <button id="auth-reset-submit" class="w-full mt-4 px-4 py-3 rounded-lg bg-primary text-white font-bold" type="button">Reset password</button>
                        <button id="auth-reset-resend-btn" class="w-full mt-2 px-4 py-3 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-200 font-semibold disabled:opacity-60" type="button">Resend reset OTP</button>
                        <p id="auth-reset-resend-timer" class="mt-2 text-xs text-slate-500 dark:text-slate-400"></p>
                    </div>

                    <p id="auth-modal-message" class="mt-4 text-sm text-slate-500 dark:text-slate-400"></p>
                </div>
            </div>
        </div>

        <script>
            (function () {
                const TOKEN_KEY = 'authToken';
                const root = document.documentElement;
                let authResolver = null;
                let pendingVerifyEmail = '';
                let pendingResetEmail = '';
                let promptResolver = null;
                let resendCooldown = 0;
                let resendTimerId = null;
                let resetResendCooldown = 0;
                let resetResendTimerId = null;

                const el = (id) => document.getElementById(id);

                const getToken = () => localStorage.getItem(TOKEN_KEY);

                const jsonFetch = async (url, options = {}) => {
                    const headers = { 'Content-Type': 'application/json', ...(options.headers || {}) };
                    const token = getToken();
                    if (token) headers.Authorization = 'Bearer ' + token;

                    const response = await fetch(url, { ...options, headers });
                    const payload = response.headers.get('content-type')?.includes('application/json')
                        ? await response.json()
                        : null;

                    if (!response.ok) throw new Error(payload?.message || `Request failed (${response.status})`);
                    return payload;
                };

                const toast = (message, type = 'info') => {
                    const host = el('app-toast-root');
                    if (!host) return;

                    const node = document.createElement('div');
                    node.className = 'pointer-events-auto px-4 py-3 rounded-xl shadow-lg border text-sm font-medium max-w-xs transition-all duration-300 translate-x-6 opacity-0';
                    if (type === 'error') {
                        node.classList.add('bg-rose-50', 'border-rose-200', 'text-rose-700');
                    } else if (type === 'success') {
                        node.classList.add('bg-emerald-50', 'border-emerald-200', 'text-emerald-700');
                    } else {
                        node.classList.add('bg-slate-50', 'border-slate-200', 'text-slate-700');
                    }
                    node.textContent = message;
                    host.appendChild(node);

                    requestAnimationFrame(() => {
                        node.classList.remove('translate-x-6', 'opacity-0');
                    });

                    setTimeout(() => {
                        node.classList.add('translate-x-6', 'opacity-0');
                        setTimeout(() => node.remove(), 280);
                    }, 2600);
                };

                const stopResendTimer = () => {
                    if (resendTimerId) {
                        clearInterval(resendTimerId);
                        resendTimerId = null;
                    }
                };

                const stopResetResendTimer = () => {
                    if (resetResendTimerId) {
                        clearInterval(resetResendTimerId);
                        resetResendTimerId = null;
                    }
                };

                const updateResendUi = () => {
                    const resendBtn = el('auth-resend-otp-btn');
                    const timerNode = el('auth-resend-timer');
                    if (!resendBtn || !timerNode) return;

                    if (resendCooldown > 0) {
                        resendBtn.disabled = true;
                        timerNode.textContent = `Resend available in ${resendCooldown}s`;
                    } else {
                        resendBtn.disabled = false;
                        timerNode.textContent = 'Did not receive OTP? Click resend.';
                    }
                };

                const startResendCooldown = (seconds = 60) => {
                    resendCooldown = Math.max(0, Number(seconds) || 0);
                    updateResendUi();
                    stopResendTimer();

                    if (resendCooldown <= 0) return;

                    resendTimerId = setInterval(() => {
                        resendCooldown = Math.max(0, resendCooldown - 1);
                        updateResendUi();
                        if (resendCooldown <= 0) stopResendTimer();
                    }, 1000);
                };

                const updateResetResendUi = () => {
                    const resendBtn = el('auth-reset-resend-btn');
                    const timerNode = el('auth-reset-resend-timer');
                    if (!resendBtn || !timerNode) return;

                    if (resetResendCooldown > 0) {
                        resendBtn.disabled = true;
                        timerNode.textContent = `Resend available in ${resetResendCooldown}s`;
                    } else {
                        resendBtn.disabled = false;
                        timerNode.textContent = 'Did not receive OTP? Click resend.';
                    }
                };

                const startResetResendCooldown = (seconds = 60) => {
                    resetResendCooldown = Math.max(0, Number(seconds) || 0);
                    updateResetResendUi();
                    stopResetResendTimer();

                    if (resetResendCooldown <= 0) return;

                    resetResendTimerId = setInterval(() => {
                        resetResendCooldown = Math.max(0, resetResendCooldown - 1);
                        updateResetResendUi();
                        if (resetResendCooldown <= 0) stopResetResendTimer();
                    }, 1000);
                };

                const openVerifyView = () => {
                    el('auth-login-view').classList.add('hidden');
                    el('auth-signup-view').classList.add('hidden');
                    el('auth-forgot-view').classList.add('hidden');
                    el('auth-reset-view').classList.add('hidden');
                    el('auth-verify-view').classList.remove('hidden');
                    startResendCooldown(60);
                };

                const openForgotView = () => {
                    el('auth-login-view').classList.add('hidden');
                    el('auth-signup-view').classList.add('hidden');
                    el('auth-verify-view').classList.add('hidden');
                    el('auth-reset-view').classList.add('hidden');
                    el('auth-forgot-view').classList.remove('hidden');
                    stopResendTimer();
                    stopResetResendTimer();
                    resendCooldown = 0;
                    resetResendCooldown = 0;
                };

                const openResetView = (email) => {
                    pendingResetEmail = String(email || '').trim().toLowerCase();
                    el('auth-login-view').classList.add('hidden');
                    el('auth-signup-view').classList.add('hidden');
                    el('auth-verify-view').classList.add('hidden');
                    el('auth-forgot-view').classList.add('hidden');
                    el('auth-reset-view').classList.remove('hidden');
                    el('auth-reset-email').value = pendingResetEmail;
                    startResetResendCooldown(60);
                };

                const switchAuthTab = (tab) => {
                    const loginTab = el('auth-tab-login');
                    const signupTab = el('auth-tab-signup');
                    const loginView = el('auth-login-view');
                    const signupView = el('auth-signup-view');
                    const verifyView = el('auth-verify-view');
                    const forgotView = el('auth-forgot-view');
                    const resetView = el('auth-reset-view');
                    if (!loginTab || !signupTab || !loginView || !signupView || !verifyView || !forgotView || !resetView) return;

                    verifyView.classList.add('hidden');
                    forgotView.classList.add('hidden');
                    resetView.classList.add('hidden');
                    stopResendTimer();
                    stopResetResendTimer();
                    resendCooldown = 0;
                    resetResendCooldown = 0;

                    if (tab === 'signup') {
                        loginView.classList.add('hidden');
                        signupView.classList.remove('hidden');
                        signupTab.className = 'flex-1 px-4 py-2 rounded-lg bg-primary text-white font-semibold';
                        loginTab.className = 'flex-1 px-4 py-2 rounded-lg bg-slate-100 dark:bg-slate-800 font-semibold';
                        return;
                    }

                    signupView.classList.add('hidden');
                    loginView.classList.remove('hidden');
                    loginTab.className = 'flex-1 px-4 py-2 rounded-lg bg-primary text-white font-semibold';
                    signupTab.className = 'flex-1 px-4 py-2 rounded-lg bg-slate-100 dark:bg-slate-800 font-semibold';
                };

                const closeAuthModal = (result = false) => {
                    const modal = el('auth-modal');
                    if (!modal) return;
                    modal.classList.add('hidden');
                    modal.classList.remove('flex');
                    root.classList.remove('overflow-hidden');
                    stopResendTimer();
                    stopResetResendTimer();
                    resendCooldown = 0;
                    resetResendCooldown = 0;
                    if (authResolver) {
                        authResolver(result);
                        authResolver = null;
                    }
                };

                const openAuthModal = (tab = 'login') => {
                    const modal = el('auth-modal');
                    if (!modal) return Promise.resolve(false);
                    switchAuthTab(tab);
                    el('auth-modal-message').textContent = '';
                    modal.classList.remove('hidden');
                    modal.classList.add('flex');
                    root.classList.add('overflow-hidden');
                    return new Promise((resolve) => {
                        authResolver = resolve;
                    });
                };

                const showPromptInput = ({ title, message = '', placeholder = '', type = 'text' }) => {
                    const modal = el('app-prompt-modal');
                    const titleNode = el('app-prompt-title');
                    const messageNode = el('app-prompt-message');
                    const input = el('app-prompt-input');
                    if (!modal || !titleNode || !messageNode || !input) return Promise.resolve(null);

                    titleNode.textContent = title || 'Input';
                    messageNode.textContent = message || '';
                    input.value = '';
                    input.placeholder = placeholder || '';
                    input.type = type || 'text';

                    modal.classList.remove('hidden');
                    modal.classList.add('flex');
                    root.classList.add('overflow-hidden');

                    setTimeout(() => input.focus(), 30);

                    return new Promise((resolve) => {
                        promptResolver = resolve;
                    });
                };

                const closePrompt = (value = null) => {
                    const modal = el('app-prompt-modal');
                    if (!modal) return;
                    modal.classList.add('hidden');
                    modal.classList.remove('flex');
                    root.classList.remove('overflow-hidden');
                    if (promptResolver) {
                        promptResolver(value);
                        promptResolver = null;
                    }
                };

                const ensureValidToken = async () => {
                    const token = getToken();
                    if (!token) return false;

                    try {
                        await jsonFetch('/api/users/profile');
                        return true;
                    } catch (_error) {
                        localStorage.removeItem(TOKEN_KEY);
                        return false;
                    }
                };

                const handleAccount = async (event) => {
                    if (event) event.preventDefault();

                    const hasValidToken = await ensureValidToken();
                    if (hasValidToken) {
                        window.location.href = '/orderhistory';
                        return;
                    }

                    const success = await openAuthModal('login');
                    if (success) window.location.href = '/orderhistory';
                };

                const bindAuthModal = () => {
                    const closeBtn = el('auth-close-btn');
                    const tabLogin = el('auth-tab-login');
                    const tabSignup = el('auth-tab-signup');
                    const openForgotBtn = el('auth-forgot-open-btn');
                    const forgotSubmit = el('auth-forgot-submit');
                    const resetSubmit = el('auth-reset-submit');
                    const resetResendBtn = el('auth-reset-resend-btn');
                    const loginSubmit = el('auth-login-submit');
                    const signupSubmit = el('auth-signup-submit');
                    const verifySubmit = el('auth-verify-submit');
                    const resendOtpBtn = el('auth-resend-otp-btn');
                    const message = el('auth-modal-message');

                    closeBtn?.addEventListener('click', () => closeAuthModal(false));
                    el('auth-modal')?.addEventListener('click', (event) => {
                        if (event.target === el('auth-modal')) closeAuthModal(false);
                    });

                    tabLogin?.addEventListener('click', () => switchAuthTab('login'));
                    tabSignup?.addEventListener('click', () => switchAuthTab('signup'));
                    openForgotBtn?.addEventListener('click', () => {
                        message.textContent = '';
                        openForgotView();
                    });

                    loginSubmit?.addEventListener('click', async () => {
                        const identifier = (el('auth-login-identifier')?.value || '').trim();
                        const password = (el('auth-login-password')?.value || '').trim();
                        if (!identifier || !password) {
                            message.textContent = 'Please enter email/phone and password.';
                            return;
                        }

                        try {
                            const payload = await jsonFetch('/api/users/login', {
                                method: 'POST',
                                body: JSON.stringify({ identifier, password })
                            });
                            localStorage.setItem(TOKEN_KEY, payload.token);
                            toast('Logged in successfully', 'success');
                            closeAuthModal(true);
                        } catch (error) {
                            message.textContent = error.message || 'Login failed';
                        }
                    });

                    signupSubmit?.addEventListener('click', async () => {
                        const name = (el('auth-signup-name')?.value || '').trim();
                        const email = (el('auth-signup-email')?.value || '').trim().toLowerCase();
                        const password = (el('auth-signup-password')?.value || '').trim();
                        if (!name || !email || !password) {
                            message.textContent = 'Please fill name, email and password.';
                            return;
                        }

                        try {
                            const payload = await jsonFetch('/api/users/signup', {
                                method: 'POST',
                                body: JSON.stringify({ name, email, password })
                            });
                            pendingVerifyEmail = email;
                            message.textContent = payload?.message || 'Signup successful. Verify your email.';
                            openVerifyView();
                            toast('Signup successful. OTP sent to your email.', 'success');
                        } catch (error) {
                            message.textContent = error.message || 'Signup failed';
                        }
                    });

                    forgotSubmit?.addEventListener('click', async () => {
                        const email = (el('auth-forgot-email')?.value || '').trim().toLowerCase();
                        if (!email) {
                            message.textContent = 'Please enter your account email.';
                            return;
                        }

                        try {
                            const payload = await jsonFetch('/api/users/forgot-password', {
                                method: 'POST',
                                body: JSON.stringify({ email })
                            });

                            message.textContent = payload?.message || 'Reset OTP sent';
                            openResetView(email);
                            toast('Reset OTP sent to your email', 'success');
                        } catch (error) {
                            message.textContent = error.message || 'Unable to send reset OTP';
                        }
                    });

                    resetSubmit?.addEventListener('click', async () => {
                        const email = pendingResetEmail || (el('auth-reset-email')?.value || '').trim().toLowerCase();
                        const otp = (el('auth-reset-otp')?.value || '').trim();
                        const newPassword = (el('auth-reset-password')?.value || '').trim();
                        const confirmPassword = (el('auth-reset-password-confirm')?.value || '').trim();

                        if (!email || !otp || !newPassword || !confirmPassword) {
                            message.textContent = 'Please fill all reset password fields.';
                            return;
                        }

                        if (newPassword !== confirmPassword) {
                            message.textContent = 'Password and confirm password must match.';
                            return;
                        }

                        try {
                            const payload = await jsonFetch('/api/users/reset-password', {
                                method: 'POST',
                                body: JSON.stringify({ email, otp, newPassword })
                            });

                            toast(payload?.message || 'Password reset successful', 'success');
                            switchAuthTab('login');
                            el('auth-login-identifier').value = email;
                            el('auth-modal-message').textContent = 'Password reset successful. Please login.';
                            pendingResetEmail = '';
                        } catch (error) {
                            message.textContent = error.message || 'Unable to reset password';
                        }
                    });

                    verifySubmit?.addEventListener('click', async () => {
                        const otp = (el('auth-verify-otp')?.value || '').trim();
                        if (!pendingVerifyEmail || !otp) {
                            message.textContent = 'Please enter OTP to verify your email.';
                            return;
                        }

                        try {
                            const payload = await jsonFetch('/api/users/verify-email', {
                                method: 'POST',
                                body: JSON.stringify({ email: pendingVerifyEmail, otp })
                            });

                            toast(payload?.message || 'Email verified successfully', 'success');
                            switchAuthTab('login');
                            el('auth-login-identifier').value = pendingVerifyEmail;
                            pendingVerifyEmail = '';
                            el('auth-modal-message').textContent = 'Email verified. Please login to continue.';
                        } catch (error) {
                            message.textContent = error.message || 'OTP verification failed';
                        }
                    });

                    resendOtpBtn?.addEventListener('click', async () => {
                        if (!pendingVerifyEmail) {
                            message.textContent = 'Please complete signup first.';
                            return;
                        }

                        if (resendCooldown > 0) return;

                        try {
                            const payload = await jsonFetch('/api/users/resend-verification-otp', {
                                method: 'POST',
                                body: JSON.stringify({ email: pendingVerifyEmail })
                            });

                            toast(payload?.message || 'OTP resent successfully', 'success');
                            startResendCooldown(60);
                        } catch (error) {
                            message.textContent = error.message || 'Unable to resend OTP';
                            const match = String(error.message || '').match(/(\d+)s/);
                            if (match?.[1]) startResendCooldown(Number(match[1]));
                        }
                    });

                    resetResendBtn?.addEventListener('click', async () => {
                        if (!pendingResetEmail) {
                            message.textContent = 'Please request reset OTP first.';
                            return;
                        }

                        if (resetResendCooldown > 0) return;

                        try {
                            const payload = await jsonFetch('/api/users/forgot-password', {
                                method: 'POST',
                                body: JSON.stringify({ email: pendingResetEmail })
                            });

                            toast(payload?.message || 'Reset OTP resent successfully', 'success');
                            startResetResendCooldown(60);
                        } catch (error) {
                            message.textContent = error.message || 'Unable to resend reset OTP';
                        }
                    });
                };

                const init = () => {
                    const searchInput = el('global-search-input');
                    const cartButton = el('global-cart-button');
                    const accountButton = el('global-account-button');
                    const mobileAccountLink = el('global-mobile-account-link');
                    const promptCancel = el('app-prompt-cancel');
                    const promptSubmit = el('app-prompt-submit');
                    const promptInput = el('app-prompt-input');

                    window.AppUI = {
                        toast,
                        openAuthModal,
                        promptInput: showPromptInput,
                        ensureAuth: async () => {
                            if (await ensureValidToken()) return true;
                            return openAuthModal('login');
                        }
                    };

                    promptCancel?.addEventListener('click', () => closePrompt(null));
                    promptSubmit?.addEventListener('click', () => closePrompt((promptInput?.value || '').trim()));
                    el('app-prompt-modal')?.addEventListener('click', (event) => {
                        if (event.target === el('app-prompt-modal')) closePrompt(null);
                    });
                    promptInput?.addEventListener('keydown', (event) => {
                        if (event.key === 'Enter') {
                            event.preventDefault();
                            closePrompt((promptInput?.value || '').trim());
                        }
                    });

                    bindAuthModal();

                    if (searchInput) {
                        const searchParams = new URLSearchParams(window.location.search);
                        const activeSearch = (searchParams.get('search') || searchParams.get('q') || '').trim();
                        if (activeSearch) searchInput.value = activeSearch;

                        searchInput.addEventListener('keydown', function (event) {
                            if (event.key !== 'Enter') return;
                            event.preventDefault();

                            const value = (searchInput.value || '').trim();

                            if (window.location.pathname === '/productlist') {
                                const params = new URLSearchParams(window.location.search);
                                params.delete('q');
                                params.set('page', '1');

                                if (value) params.set('search', value);
                                else params.delete('search');

                                const query = params.toString();
                                window.location.href = query ? '/productlist?' + query : '/productlist';
                                return;
                            }

                            window.location.href = value ? '/productlist?search=' + encodeURIComponent(value) : '/productlist';
                        });
                    }

                    cartButton?.addEventListener('click', function () {
                        window.location.href = '/cart';
                    });

                    if (accountButton) {
                        ensureValidToken().then((hasValidToken) => {
                            if (hasValidToken) accountButton.classList.add('ring-2', 'ring-primary/40');
                        });

                        accountButton.addEventListener('click', handleAccount);
                        accountButton.title = 'Click to login/order history. Right-click to logout.';
                        accountButton.addEventListener('contextmenu', function (event) {
                            event.preventDefault();
                            if (!getToken()) return;
                            localStorage.removeItem(TOKEN_KEY);
                            toast('Logged out successfully', 'success');
                        });
                    }

                    mobileAccountLink?.addEventListener('click', handleAccount);
                };

                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', init);
                } else {
                    init();
                }
            })();
        </script>

