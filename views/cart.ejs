<%- include('partials/header') %>
<main class="px-2 md:px-6 lg:px-10 py-6">
    <div class="flex flex-col gap-2 mb-4">
        <h2 class="text-2xl md:text-4xl font-black tracking-tight">Your Cart</h2>
        <p id="cart-subtitle" class="text-slate-500 dark:text-slate-400">Loading cart...</p>
    </div>

    <div class="flex flex-col lg:flex-row gap-12">
        <div id="cart-items" class="max-w-4xl w-full space-y-5"></div>

        <aside class="w-full lg:w-[400px] space-y-6">
            <div class="bg-white dark:bg-slate-900/50 border border-slate-100 dark:border-slate-800 p-8 rounded-xl shadow-sm">
                <h3 class="text-xl font-bold mb-6">Order Summary</h3>

                <div class="mb-8">
                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-2">Discount Code</label>
                    <div class="flex gap-2">
                        <input id="cart-coupon-code" class="flex-1 bg-background-light dark:bg-slate-800 border-none rounded-lg text-sm px-4 focus:ring-2 focus:ring-primary/50" placeholder="Enter code" type="text"/>
                        <button id="cart-apply-coupon-btn" class="bg-primary/20 text-primary font-bold px-4 py-2 rounded-lg text-sm hover:bg-primary/30 transition-colors" type="button">Apply</button>
                        <button id="cart-remove-coupon-btn" class="hidden bg-slate-100 text-slate-700 font-bold px-4 py-2 rounded-lg text-sm hover:bg-slate-200 transition-colors" type="button">Remove</button>
                    </div>
                    <p id="cart-coupon-message" class="text-xs text-slate-500 mt-2"></p>
                </div>

                <div id="cart-summary" class="space-y-4 mb-8">
                    <div class="flex justify-between text-slate-600 dark:text-slate-400">
                        <span>Subtotal</span>
                        <span>₹0.00</span>
                    </div>
                    <div class="flex justify-between text-slate-600 dark:text-slate-400">
                        <span>Shipping</span>
                        <span class="text-primary font-medium italic">₹0.00</span>
                    </div>
                    <div class="flex justify-between text-slate-600 dark:text-slate-400">
                        <span>Estimated Tax</span>
                        <span>₹0.00</span>
                    </div>
                    <div class="pt-4 border-t border-slate-100 dark:border-slate-800 flex justify-between items-end">
                        <span class="text-lg font-bold">Total</span>
                        <span class="text-2xl font-black text-primary">₹0.00</span>
                    </div>
                </div>

                <button id="cart-checkout-btn" class="w-full bg-primary hover:bg-emerald-500 text-white font-bold py-4 rounded-xl flex items-center justify-center gap-2 transition-all transform active:scale-[0.98] shadow-lg shadow-primary/20" type="button">
                    <span class="material-symbols-outlined">lock</span>
                    Secure Checkout
                </button>
            </div>

            <div class="bg-primary/5 rounded-xl p-4 flex items-start gap-4 border border-primary/10">
                <span class="material-symbols-outlined text-primary">local_shipping</span>
                <p class="text-sm text-slate-600 dark:text-slate-400">
                    <strong class="text-slate-900 dark:text-slate-200">Complimentary Standard Shipping.</strong> Your order is carbon-neutral and arrives in eco-friendly packaging.
                </p>
            </div>
        </aside>
    </div>
</main>

<script src="/js/pages/cart.page.js"></script>
<%- include('partials/footer') %>