 
 <%- include('partials/header') %>
 
 <main class="w-full px-6 py-8">
<!-- Breadcrumbs -->
<div class="flex items-center gap-2 mb-6 text-sm">
<a class="text-slate-500 dark:text-slate-400 hover:text-primary" href="/">Home</a>
<span class="material-symbols-outlined text-[16px] text-slate-400">chevron_right</span>
<a class="text-slate-500 dark:text-slate-400 hover:text-primary" href="/orderhistory">Orders</a>
<span class="material-symbols-outlined text-[16px] text-slate-400">chevron_right</span>
<span id="od-order-number" class="text-primary font-medium">Order #</span>
</div>
<!-- Header Action Area -->
<div class="flex flex-wrap justify-between items-end gap-4 mb-8">
<div class="flex flex-col gap-1">
<h1 class="text-slate-900 dark:text-slate-100 text-4xl font-black tracking-tight">Order Details</h1>
<p id="od-meta" class="text-slate-500 dark:text-slate-400 text-lg">Placed on -</p>
</div>
<div class="flex gap-3">
<button class="flex items-center justify-center rounded-xl h-12 px-6 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-200 text-sm font-bold hover:bg-slate-200 dark:hover:bg-slate-700 transition-all border border-slate-200 dark:border-slate-700">
<span class="material-symbols-outlined mr-2">download</span>
                        Download Invoice
                    </button>
<button class="flex items-center justify-center rounded-xl h-12 px-6 bg-primary text-white text-sm font-bold hover:bg-opacity-90 transition-all shadow-lg shadow-primary/20">
<span class="material-symbols-outlined mr-2">reorder</span>
                        Reorder All Items
                    </button>
</div>
</div>
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
<!-- Left Column: Tracking and Items -->
<div class="lg:col-span-2 space-y-8">
<!-- Tracking Timeline Card -->
<div class="bg-white dark:bg-slate-900 rounded-xl p-8 border border-slate-200 dark:border-slate-800 shadow-sm">
<div class="flex justify-between items-center mb-8">
<h3 class="text-xl font-bold">Delivery Status</h3>
<span id="od-delivery-status" class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-full text-xs font-bold uppercase tracking-wider">Pending</span>
</div>
<div id="od-timeline" class="space-y-4"></div>
</div>
<!-- Items List -->
<div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm">
<div class="p-6 border-b border-slate-200 dark:border-slate-800">
<h3 class="text-xl font-bold">Ordered Items</h3>
</div>
<div id="od-items" class="divide-y divide-slate-100 dark:divide-slate-800"></div>
</div>
</div>
<!-- Right Column: Sidebar (Summary and Shipping) -->
<div class="space-y-8">
<!-- Order Summary Card -->
<div class="bg-white dark:bg-slate-900 rounded-xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm">
<h3 class="text-lg font-bold mb-6 border-b border-slate-100 dark:border-slate-800 pb-4">Order Summary</h3>
<div id="od-summary" class="space-y-4">
<div class="flex justify-between text-slate-600 dark:text-slate-400">
<span>Subtotal</span>
<span>$98.99</span>
</div>
<div class="flex justify-between text-slate-600 dark:text-slate-400">
<span>Shipping</span>
<span class="text-green-600 font-medium">FREE</span>
</div>
<div class="flex justify-between text-slate-600 dark:text-slate-400">
<span>Estimated Tax</span>
<span>$7.92</span>
</div>
<div class="pt-4 border-t border-slate-100 dark:border-slate-800 flex justify-between items-center">
<span class="font-bold text-xl">Total</span>
<span class="font-black text-2xl text-primary">$106.91</span>
</div>
</div>
</div>
<!-- Shipping Info Card -->
<div class="bg-white dark:bg-slate-900 rounded-xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm">
<div class="flex items-center gap-2 mb-4">
<span class="material-symbols-outlined text-primary">location_on</span>
<h3 class="text-lg font-bold">Shipping Address</h3>
</div>
<div id="od-shipping-address" class="text-slate-600 dark:text-slate-400 leading-relaxed">
<p>-</p>
</div>
</div>
<!-- Payment Info Card -->
<div class="bg-white dark:bg-slate-900 rounded-xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm">
<div class="flex items-center gap-2 mb-4">
<span class="material-symbols-outlined text-primary">credit_card</span>
<h3 class="text-lg font-bold">Payment Method</h3>
</div>
<div id="od-payment-method" class="flex items-center gap-4 bg-slate-50 dark:bg-slate-800/50 p-3 rounded-lg border border-slate-100 dark:border-slate-800">
<div class="w-12 h-8 bg-white dark:bg-slate-700 rounded border border-slate-200 dark:border-slate-600 flex items-center justify-center font-bold text-xs italic text-blue-800 dark:text-blue-400">
                                -
                            </div>
<div>
<p class="font-medium">-</p>
<p class="text-xs text-slate-500">-</p>
</div>
</div>
<div class="mt-6">
<h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Billing Address</h4>
<p id="od-billing-address" class="text-sm text-slate-600 dark:text-slate-400">Same as shipping address</p>
</div>
</div>
<!-- Map Location (Implicit Component) -->
<div class="rounded-xl overflow-hidden h-48 relative border border-slate-200 dark:border-slate-800">
<img class="w-full h-full object-cover grayscale opacity-50" data-alt="Stylized map showing San Francisco area" data-location="San Francisco" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCGa0et8VOyxTMyb5rJ5_zKlF2vuYiO1MMsaq7vc-KUB-WcQlZlZnjpLGOec4o6u-ILS5nZdOq9XK-xwr1DV2G0IPChFWvgI4223NDNV5RKqq_EzSgqd2qGvHOpFv2rsSnG_2uF_uYd3BfrP0wlcdEaLMppxkYM_-kcP6E_bIz1768kvRcDHsflKiIEOX2rgDrGjm6bmod_Sw8gCWSsgEwjwZbiAmJOg1azSfHR6Nj6PZ6ddQx5w67FZWs-Ycl-no8KKhSp-dCHsBm0"/>
<div class="absolute inset-0 bg-primary/10 flex items-center justify-center">
<div class="bg-white dark:bg-slate-900 p-2 rounded-full shadow-lg">
<span class="material-symbols-outlined text-primary text-[32px]">location_on</span>
</div>
</div>
<div class="absolute bottom-2 left-2 bg-white/90 dark:bg-slate-900/90 backdrop-blur-sm px-3 py-1 rounded text-[10px] font-bold text-slate-500">
                            TRACKING LIVE
                        </div>
</div>
</div>
</div>
</main>

<script src="/js/pages/orderdetails.page.js"></script>
<%- include('partials/footer') %>