# Server
PORT=5000

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=derma_ecom

# Optional DB pool tuning
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=50
DB_CONNECT_TIMEOUT_MS=10000
DB_ACQUIRE_TIMEOUT_MS=10000

# JWT
JWT_ACCESS_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# SMTP (required for OTP/password emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=app_password_or_smtp_password
SMTP_FROM=no-reply@example.com
SMTP_SECURE=false

# Razorpay (optional unless online payments enabled)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
